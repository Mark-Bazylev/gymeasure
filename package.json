{
  "name": "gymeasure",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @gymeasure/api",
    "dev:mobile": "npm run start -w @gymeasure/mobile",
    "build:api": "npm run build -w @gymeasure/api",
    "db:generate": "npm run db:generate -w @gymeasure/api",
    "db:migrate": "npm run db:migrate -w @gymeasure/api",
    "db:push": "npm run db:push -w @gymeasure/api"
  },
  "engines": {
    "node": ">=20"
  }
}
