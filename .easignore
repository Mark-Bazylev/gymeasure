# When .easignore exists, EAS ignores .gitignore — keep both in sync.
node_modules/
.git/
.expo/
dist/
build/
.turbo/
coverage/
**/.env
**/.env.*
!**/.env.example

# Native / local build artifacts
**/android/
**/ios/
/android/
/app.json
/tsconfig.json

# Large local media (catalog images are hosted in prod)
apps/api/media/
**/media/

# Misc
**/.DS_Store
**/*.log
**/tmp/
