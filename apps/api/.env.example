# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
DATABASE_SSL=true

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Google Sign-In (Android first). Audience list for ID token verification.
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=

# Server
PORT=4000
PUBLIC_API_URL=http://localhost:4000

# Local media fallback when R2 is not configured
MEDIA_DIR=./media

# Cloudflare R2 (owned exercise images)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=gymeasure-exercises
# R2_PUBLIC_BASE_URL=https://media.example.com

# Allow POST /exercises/import (also use npm run catalog:import)
ALLOW_CATALOG_IMPORT=false
