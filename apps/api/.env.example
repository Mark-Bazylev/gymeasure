# Database (Neon)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
DATABASE_SSL=true

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=4000

# Optional ExerciseDB (RapidAPI). Without it, OSS/search fallback is used.
# EXERCISEDB_API_KEY=
# EXERCISEDB_BASE_URL=https://exercisedb-api-v1.p.rapidapi.com
# EXERCISEDB_HOST=exercisedb-api-v1.p.rapidapi.com
# EXERCISEDB_OSS_URL=https://exercisedb.dev/api/v1
