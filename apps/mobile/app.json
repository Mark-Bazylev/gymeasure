{
  "expo": {
    "name": "Gymeasure",
    "slug": "gymeasure",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gymeasure",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1F17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymeasure.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1F17",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.gymeasure.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
